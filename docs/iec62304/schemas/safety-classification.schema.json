{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdux.dev/schemas/iec62304/safety-classification.schema.json",
  "title": "IEC 62304 Software Safety Classification Schema",
  "description": "Schema for recording an IEC 62304 §4.3 software safety classification decision. Restricted to Class B / Class C: mdux_core::SafetyClass has no Class A variant, so this schema does not imply Class A support for anything built on MduX-rust.",
  "$comment": "Schema version 1.0.0.",
  "type": "object",
  "required": ["classification_id", "software_system", "hazard_analysis", "classification_result"],
  "properties": {
    "classification_id": {
      "type": "string",
      "pattern": "^SC-[0-9]{4}-[0-9]{3}$",
      "description": "e.g. 'SC-2026-001'."
    },
    "software_system": {
      "type": "object",
      "required": ["name", "version", "description", "medical_device_context"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "medical_device_context": {
          "type": "object",
          "properties": {
            "device_type": { "type": "string" },
            "intended_use": { "type": "string" },
            "patient_population": { "type": "string" },
            "clinical_environment": { "type": "string" }
          }
        }
      }
    },
    "hazard_analysis": {
      "type": "object",
      "required": ["hazards_identified", "analysis_method", "analysis_date"],
      "properties": {
        "analysis_method": {
          "type": "string",
          "enum": ["Failure_Mode_Analysis", "Hazard_Analysis", "Risk_Analysis", "Fault_Tree_Analysis"]
        },
        "analysis_date": { "$ref": "#/$defs/iso_date" },
        "analysts": { "type": "array", "items": { "$ref": "#/$defs/person" } },
        "hazards_identified": {
          "type": "array",
          "items": { "$ref": "hazard.schema.json" }
        }
      }
    },
    "classification_result": {
      "type": "object",
      "required": ["overall_classification", "classification_rationale", "approval"],
      "properties": {
        "overall_classification": {
          "type": "string",
          "enum": ["Class_B", "Class_C"],
          "description": "Corresponds to mdux_core::SafetyClass::{B,C}. No Class_A value exists in this schema."
        },
        "classification_rationale": {
          "type": "object",
          "properties": {
            "primary_justification": { "type": "string" },
            "contributing_hazards": { "type": "array", "items": { "type": "string" } },
            "worst_case_scenario": { "type": "string" },
            "conservative_approach_applied": { "type": "boolean" }
          }
        },
        "approval": {
          "type": "object",
          "required": ["approved_by", "approval_date"],
          "properties": {
            "approved_by": { "$ref": "#/$defs/person" },
            "approval_date": { "$ref": "#/$defs/iso_date" },
            "approval_conditions": { "type": "array", "items": { "type": "string" } },
            "review_board": { "type": "array", "items": { "$ref": "#/$defs/person" } }
          }
        }
      }
    }
  },
  "$defs": {
    "iso_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date in ISO 8601 format (YYYY-MM-DD)"
    },
    "person": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "qualifications": { "type": "array", "items": { "type": "string" } },
        "organization": { "type": "string" }
      }
    }
  }
}
